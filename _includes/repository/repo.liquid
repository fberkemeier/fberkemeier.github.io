{% assign repo_item = include.repository %}
{% assign repo_full = repo_item.name | default: repo_item %}
{% assign repo_url = repo_full | split: '/' %}
{% assign owner = repo_url[0] %}
{% assign name  = repo_url[1] %}
{% assign repo_link = "https://github.com/" | append: repo_full %}
{% assign about = repo_item.about | default: "" %}

<div class="repo p-2 d-flex"
     style="flex: 0 0 50%; max-width: 50%; box-sizing: border-box;">
  <div class="repo-card w-100 d-flex flex-column text-center"
       style="padding:1.25rem; border:1px solid rgba(0,0,0,0.1); border-radius:1rem; height:160px;">

    <!-- Title -->
    <div style="display:flex; justify-content:center; align-items:flex-start; gap:0.5rem; margin:0; padding:0;">
      <img src="/assets/img/githublogo.svg"
           alt="GitHub"
           style="width:16px; height:16px; opacity:0.85; flex:0 0 auto; margin-top:2px;">
      <a href="{{ repo_link }}" target="_blank" rel="noopener"
         style="
           text-decoration:none;
           color:inherit;
           font-weight:600;
           font-size:0.98rem;
           line-height:1.15;
           display:inline-block;
           max-width: calc(100% - 22px);
           white-space: normal;
           overflow-wrap: anywhere;
           word-break: break-word;
           hyphens: auto;
         ">
        {{ repo_full }}
      </a>
    </div>

    <!-- About (from YAML) -->
    <div style="flex:1; display:flex; align-items:center; justify-content:center; margin:0; padding:0;">
      <div style="
          font-size:0.92rem;
          line-height:1.35;
          opacity:0.85;
          padding:0 0.75rem;
          overflow-wrap:anywhere;
          word-break:break-word;
          hyphens:auto;

          display:-webkit-box;
          -webkit-line-clamp:5;
          -webkit-box-orient:vertical;
          overflow:hidden;
        ">
        {% if about and about != "" %}
          {{ about }}
        {% else %}
          <span style="opacity:0.6;">(Description available on GitHub.)</span>
        {% endif %}
      </div>
    </div>

  </div>
</div>